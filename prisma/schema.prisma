// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  kos       Kos[]    @relation("OwnerKos")
  bookings  Booking[]
  comments  Comment[]
  createdAt DateTime @default(now())
}

model Kos {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  gender    String
  price     Int
  owner     User     @relation("OwnerKos", fields: [ownerId], references: [id])
  ownerId   Int
  rooms     Room[]
  facilities Facility[]
  comments  Comment[]
}

model Room {
  id      Int    @id @default(autoincrement())
  number  String
  status  String
  kos     Kos    @relation(fields: [kosId], references: [id])
  kosId   Int
  bookings Booking[]
}

model Facility {
  id     Int  @id @default(autoincrement())
  name   String
  kos    Kos  @relation(fields: [kosId], references: [id])
  kosId  Int
}

model Booking {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    Int
  status    BookingStatus @default(PENDING)
  createdAt DateTime @default(now())
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String
  reply   String?
  user    User   @relation(fields: [userId], references: [id])
  userId  Int
  kos     Kos    @relation(fields: [kosId], references: [id])
  kosId   Int
}

enum Role {
  SOCIETY
  OWNER
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}
